FROM python:3.12-slim

# Cài đặt các công cụ build hệ thống cần thiết để compile thư viện C++ và xử lý âm thanh
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libsndfile1-dev \
    build-essential \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Nâng cấp bộ công cụ pip và cài đặt các dependencies nền tảng
RUN python -m pip install -U pip setuptools wheel packaging ninja

# Cài đặt Torch trước (bản CPU hoặc CUDA tùy nhu cầu, ở đây mặc định bản CUDA để chạy model)
# Lưu ý: Quá trình này tốn nhiều RAM và dung lượng
RUN pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121

# Cài đặt flash-attn (Quá trình này sẽ rất lâu trên bản slim vì phải compile từ đầu)
RUN pip install --no-cache-dir flash-attn --no-build-isolation

# Cài đặt các dependencies từ file requirements
COPY requirement.txt .
RUN pip install --no-cache-dir -r requirement.txt

COPY . .

CMD ["python"]
